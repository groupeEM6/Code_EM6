#include <SPI.h>
#include <RF24.h>
#include <Wire.h>

// --- CONFIGURATION NRF24L01 ---
#define pinCE   A1 //ici faut donner les bons pins
#define pinCSN  A0
RF24 radio(pinCE, pinCSN);
const byte adresse[6] = "00001"; // Doit être la même que l'adversaire

// --- CONFIGURATION BLUETOOTH (Serial1 sur Nano Every) ---
#define bluetooth Serial1 

// --- VARIABLES DE JEU ---
int board[9] = {0}; // 0=vide, 1=adversaire (X), -1=robot (O)
bool robotEnTrainDeJouer = false;

// --- LOGIQUE DU JEU (MINIMAX) ---

int gagnant(int b[9]) {
    const int L[8][3] = {{0,1,2},{3,4,5},{6,7,8},{0,3,6},{1,4,7},{2,5,8},{0,4,8},{2,4,6}};
    for (int i = 0; i < 8; i++) {
        if (b[L[i][0]] != 0 && b[L[i][0]] == b[L[i][1]] && b[L[i][1]] == b[L[i][2]]) return b[L[i][0]];
    }
    return 0;
}

int minimax(int b[9], int joueur) {
    int win = gagnant(b);
    if (win == -1) return 1;
    if (win == 1) return -1;
    bool plein = true;
    for(int i=0; i<9; i++) if(b[i]==0) plein = false;
    if(plein) return 0;

    int meilleur = (joueur == -1 ? -1000 : 1000);
    for (int i = 0; i < 9; i++) {
        if (b[i] == 0) {
            b[i] = joueur;
            int score = minimax(b, -joueur);
            b[i] = 0;
            if (joueur == -1) meilleur = max(meilleur, score);
            else meilleur = min(meilleur, score);
        }
    }
    return meilleur;
}

int calculerMeilleurCoup() {
    int meilleurScore = -1000;
    int coup = -1;
    for (int i = 0; i < 9; i++) {
        if (board[i] == 0) {
            board[i] = -1;
            int score = minimax(board, 1);
            board[i] = 0;
            if (score > meilleurScore) {
                meilleurScore = score;
                coup = i;
            }
        }
    }
    return coup;
}

void setup() {
    Serial.begin(9600);      // Console PC
    bluetooth.begin(9600);   // Bluetooth (Pins 0 et 1)
    Wire.begin();            // Maître I2C (Pins A4/A5)
    
    // Initialisation NRF
    if (!radio.begin()) {
        bluetooth.println("Erreur: NRF24 non detecte !");
    }
    radio.openReadingPipe(1, adresse);
    radio.setPALevel(RF24_PA_MIN);
    radio.startListening(); 

    bluetooth.println("--- SYSTEME PRET : EN ATTENTE DU JOUEUR ---");
}

void loop() {
    // 1. ECOUTER L'ADVERSAIRE (NRF)
    if (!robotEnTrainDeJouer && radio.available()) {
        char msg[32] = "";
        radio.read(&msg, sizeof(msg));
        int coupAdversaire = atoi(msg); // Convertit "3" en 3

        if (coupAdversaire >= 0 && coupAdversaire <= 8 && board[coupAdversaire] == 0) {
            board[coupAdversaire] = 1;
            bluetooth.print("Adversaire a joue case : "); bluetooth.println(coupAdversaire);

            // CALCUL DU COUP ROBOT
            int monCoup = calculerMeilleurCoup();
            if (monCoup != -1) {
                board[monCoup] = -1;
                
                // ENVOYER L'ORDRE A L'ARDUINO B (PILOTEUR)
                Wire.beginTransmission(8); // Adresse de B
                Wire.write(monCoup); 
                Wire.endTransmission();
                
                robotEnTrainDeJouer = true; // On passe en mode "attente du mouvement"
                bluetooth.print("Robot joue case : "); bluetooth.println(monCoup);
            }
        }
    }

    // 2. POLLING (SPAM) : DEMANDER A L'ARDUINO B S'IL A FINI
    if (robotEnTrainDeJouer) {
        static unsigned long dernierCheck = 0;
        if (millis() - dernierCheck > 500) { // On demande toutes les 500ms
            dernierCheck = millis();
            
            Wire.requestFrom(8, 1); // Demande 1 octet à B
            if (Wire.available()) {
                byte statut = Wire.read();
                if (statut == 0x01) { // 0x01 signifie "Fini et revenu au depart"
                    robotEnTrainDeJouer = false;
                    bluetooth.println("Robot a fini son mouvement.");
                    
                    // Envoyer notre coup à l'adversaire pour qu'il sache qu'on a joué
                    radio.stopListening();
                    // On peut envoyer un message ici via radio.write()
                    radio.startListening();
                }
            }
        }
    }
}
