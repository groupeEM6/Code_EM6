#include <SPI.h>
#include <RF24.h>
#include <Wire.h>

// --- CONFIGURATION NRF ---
#define pinCE   A1
#define pinCSN  A0
#define tunnel  "PIPE1"
RF24 radio(pinCE, pinCSN);
const byte adresse[6] = tunnel;

// --- CONFIGURATION BLUETOOTH (Nano Every) ---
#define bluetooth Serial1 

// --- VARIABLES DE JEU ---
int board[9] = {0}; 
bool robotEnTrainDeJouer = false;

// --- LOGIQUE MINIMAX ---
int gagnant(int b[9]) {
    const int L[8][3] = {{0,1,2},{3,4,5},{6,7,8},{0,3,6},{1,4,7},{2,5,8},{0,4,8},{2,4,6}};
    for (int i = 0; i < 8; i++) {
        if (b[L[i][0]] != 0 && b[L[i][0]] == b[L[i][1]] && b[L[i][1]] == b[L[i][2]]) return b[L[i][0]];
    }
    return 0;
}

int minimax(int b[9], int joueur) {
    int win = gagnant(b);
    if (win == -1) return 1;
    if (win == 1) return -1;
    bool plein = true;
    for(int i=0; i<9; i++) if(b[i]==0) plein = false;
    if(plein) return 0;

    int meilleur = (joueur == -1 ? -1000 : 1000);
    for (int i = 0; i < 9; i++) {
        if (b[i] == 0) {
            b[i] = joueur;
            int score = minimax(b, -joueur);
            b[i] = 0;
            if (joueur == -1) meilleur = max(meilleur, score);
            else meilleur = min(meilleur, score);
        }
    }
    return meilleur;
}

int calculerMeilleurCoup() {
    int meilleurScore = -1000;
    int coup = -1;
    for (int i = 0; i < 9; i++) {
        if (board[i] == 0) {
            board[i] = -1;
            int score = minimax(board, 1);
            board[i] = 0;
            if (score > meilleurScore) {
                meilleurScore = score;
                coup = i;
            }
        }
    }
    return coup;
}

void setup() {
    Serial.begin(9600);
    bluetooth.begin(9600);
    Wire.begin(); 
    
    radio.begin();
    radio.openReadingPipe(1, adresse);
    radio.openWritingPipe(adresse);
    radio.setPALevel(RF24_PA_MIN);
    radio.startListening(); 

    bluetooth.println("--- SYSTEME PRET ---");
}

void loop() {
    // 1. ECOUTER L'ADVERSAIRE (NRF)
    if (!robotEnTrainDeJouer && radio.available()) {
        char msgRecu[32] = ""; // Ta variable
        radio.read(&msgRecu, sizeof(msgRecu));
        int coupAdversaire = atoi(msgRecu); 

        if (coupAdversaire >= 0 && coupAdversaire <= 8 && board[coupAdversaire] == 0) {
            board[coupAdversaire] = 1;
            bluetooth.print("Adversaire joue : "); bluetooth.println(coupAdversaire);

            int monCoup = calculerMeilleurCoup();
            if (monCoup != -1) {
                board[monCoup] = -1;
                
                // ORDRE I2C VERS ARDUINO B
                Wire.beginTransmission(8);
                Wire.write(monCoup); 
                Wire.endTransmission();
                
                robotEnTrainDeJouer = true;
                bluetooth.print("Robot joue : "); bluetooth.println(monCoup);
            }
        }
    }

    // 2. POLLING ("spam")
    if (robotEnTrainDeJouer) {
        static unsigned long dernierCheck = 0;
        if (millis() - dernierCheck > 500) {
            dernierCheck = millis();
            
            Wire.requestFrom(8, 1); 
            if (Wire.available()) {
                byte statut = Wire.read();
                if (statut == 0x01) { 
                    robotEnTrainDeJouer = false;
                    bluetooth.println("Mouvement termine. Pret pour le tour suivant.");
                    
                    // Envoyer ton coup à l'adversaire via NRF
                    radio.stopListening();
                    char msgEnvoi[32];
                    itoa(board[calculerMeilleurCoup()], msgEnvoi, 10); 
                    radio.write(&msgEnvoi, sizeof(msgEnvoi));
                    radio.startListening();
                }
            }
        }
    }
}
