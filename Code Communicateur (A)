#include <SPI.h>
#include <RF24.h>
#include <Wire.h>

// --- CONFIGURATION NRF ---
#define pinCE   A1
#define pinCSN  A0
#define tunnel  "PIPE1"
RF24 radio(pinCE, pinCSN);
const byte adresse[6] = tunnel;

// --- CONFIGURATION BLUETOOTH ---
#define bluetooth Serial1 

// --- ÉTATS I2C ---
#define FINI    0x01
#define TRAVAIL 0x02

// --- VARIABLES DE JEU ---
int board[9] = {0}; 
bool robotEnTrainDeJouer = false;
int dernierCoupRobot = -1; // Pour s'en souvenir et l'envoyer à la fin

// --- LOGIQUE MINIMAX ---
int gagnant(int b[9]) {
    const int L[8][3] = {{0,1,2},{3,4,5},{6,7,8},{0,3,6},{1,4,7},{2,5,8},{0,4,8},{2,4,6}};
    for (int i = 0; i < 8; i++) {
        if (b[L[i][0]] != 0 && b[L[i][0]] == b[L[i][1]] && b[L[i][1]] == b[L[i][2]]) return b[L[i][0]];
    }
    return 0;
}

int minimax(int b[9], int joueur) {
    int win = gagnant(b);
    if (win == -1) return 1;
    if (win == 1) return -1;
    bool plein = true;
    for(int i=0; i<9; i++) if(b[i]==0) plein = false;
    if(plein) return 0;

    int meilleur = (joueur == -1 ? -1000 : 1000);
    for (int i = 0; i < 9; i++) {
        if (b[i] == 0) {
            b[i] = joueur;
            int score = minimax(b, -joueur);
            b[i] = 0;
            if (joueur == -1) meilleur = max(meilleur, score);
            else meilleur = min(meilleur, score);
        }
    }
    return meilleur;
}

int calculerMeilleurCoup() {
    int meilleurScore = -1000;
    int coup = -1;
    for (int i = 0; i < 9; i++) {
        if (board[i] == 0) {
            board[i] = -1;
            int score = minimax(board, 1);
            board[i] = 0;
            if (score > meilleurScore) {
                meilleurScore = score;
                coup = i;
            }
        }
    }
    return coup;
}

void setup() {
    Serial.begin(9600);      
    bluetooth.begin(9600);   
    Wire.begin();            
    
    if (!radio.begin()) {
        bluetooth.println("Erreur: NRF24 non detecte !");
    }
    radio.setChannel(109);
    radio.openReadingPipe(1, adresse);
    radio.openWritingPipe(adresse); // Nécessaire pour répondre
    radio.setPALevel(RF24_PA_MIN);
    radio.startListening(); 

    bluetooth.println("--- SYSTEME PRET : EN ATTENTE DU JOUEUR ---");
}

void loop() {
    // 1. ÉCOUTER L'ADVERSAIRE (NRF24)
    if (!robotEnTrainDeJouer && radio.available()) {
        char msgRecu[32] = "";
        radio.read(&msgRecu, sizeof(msgRecu));
        int coupAdversaire = atoi(msgRecu); 

        if (coupAdversaire >= 0 && coupAdversaire <= 8 && board[coupAdversaire] == 0) {
            board[coupAdversaire] = 1;
            bluetooth.print("Adversaire joue case : "); bluetooth.println(coupAdversaire);

            // CALCUL DU COUP DU ROBOT
            dernierCoupRobot = calculerMeilleurCoup();
            if (dernierCoupRobot != -1) {
                board[dernierCoupRobot] = -1;
                
                // ENVOI DE L'ORDRE À L'ARDUINO B
                Wire.beginTransmission(8);
                Wire.write(dernierCoupRobot); 
                Wire.endTransmission();
                
                robotEnTrainDeJouer = true; 
                bluetooth.print("Robot dessine case : "); bluetooth.println(dernierCoupRobot);
            }
        }
    }

    // 2. SURVEILLANCE DU MOUVEMENT (I2C) ET RÉPONSE RADIO
    if (robotEnTrainDeJouer) {
        static unsigned long dernierCheck = 0;
        if (millis() - dernierCheck > 500) { 
            dernierCheck = millis();
            
            Wire.requestFrom(8, 1); 
            if (Wire.available()) {
                byte statut = Wire.read();
                if (statut == FINI) { 
                    
                    // --- ENVOI DU COUP À L'ADVERSAIRE PAR NRF ---
                    radio.stopListening(); // On bascule en mode émetteur
                    char msgEnvoi[32];
                    itoa(dernierCoupRobot, msgEnvoi, 10);
                    radio.write(&msgEnvoi, sizeof(msgEnvoi));
                    radio.startListening(); // On repasse en mode écoute
                    // --------------------------------------------

                    robotEnTrainDeJouer = false;
                    bluetooth.print("Coup "); bluetooth.print(dernierCoupRobot);
                    bluetooth.println(" envoye à l'adversaire. Tour fini.");
                }
            }
        }
    }
}
