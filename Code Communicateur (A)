#include <SPI.h>
#include <RF24.h>
#include <Wire.h>

// --- CONFIGURATION NRF (Ta structure) ---
#define pinCE   A1
#define pinCSN  A0
#define tunnel  "PIPE1"
RF24 radio(pinCE, pinCSN);
const byte adresse[6] = tunnel;

// --- CHOIX DU RÔLE ---
// 1 = Tu commences (Emetteur)
// 0 = L'adversaire commence (Recepteur)
bool role = 1; 

// --- CONFIGURATION BLUETOOTH ---
#define bluetooth Serial1 

// --- ÉTATS I2C ---
#define FINI    0x01
#define TRAVAIL 0x02

// --- VARIABLES DE JEU ---
int board[9] = {0}; 
bool robotEnTrainDeJouer = false;
int dernierCoupRobot = -1;

// --- LOGIQUE MINIMAX ---
int gagnant(int b[9]) {
    const int L[8][3] = {{0,1,2},{3,4,5},{6,7,8},{0,3,6},{1,4,7},{2,5,8},{0,4,8},{2,4,6}};
    for (int i = 0; i < 8; i++) {
        if (b[L[i][0]] != 0 && b[L[i][0]] == b[L[i][1]] && b[L[i][1]] == b[L[i][2]]) return b[L[i][0]];
    }
    return 0;
}

int minimax(int b[9], int joueur) {
    int win = gagnant(b);
    if (win == -1) return 1;
    if (win == 1) return -1;
    bool plein = true;
    for(int i=0; i<9; i++) if(b[i]==0) plein = false;
    if(plein) return 0;
    int meilleur = (joueur == -1 ? -1000 : 1000);
    for (int i = 0; i < 9; i++) {
        if (b[i] == 0) {
            b[i] = joueur;
            int score = minimax(b, -joueur);
            b[i] = 0;
            if (joueur == -1) meilleur = max(meilleur, score);
            else meilleur = min(meilleur, score);
        }
    }
    return meilleur;
}

int calculerMeilleurCoup() {
    int meilleurScore = -1000, coup = -1;
    for (int i = 0; i < 9; i++) {
        if (board[i] == 0) {
            board[i] = -1;
            int score = minimax(board, 1);
            board[i] = 0;
            if (score > meilleurScore) { meilleurScore = score; coup = i; }
        }
    }
    return coup;
}

void setup() {
    Serial.begin(9600);
    bluetooth.begin(9600);
    Wire.begin(); 

    radio.begin();
    radio.setChannel(109);
    radio.setPALevel(RF24_PA_MIN);
    radio.setRetries(5, 15);

    if (role == 0) {
        Serial.println("Mode : Recepteur (L'adversaire commence)");
        radio.openReadingPipe(1, adresse);
        radio.startListening();
    } else {
        Serial.println("Mode : Emetteur (Je commence)");
        radio.openWritingPipe(adresse);
        radio.stopListening();
        
        // --- JOUER LE PREMIER COUP IMMEDIATEMENT ---
        dernierCoupRobot = calculerMeilleurCoup();
        board[dernierCoupRobot] = -1;
        
        Wire.beginTransmission(8);
        Wire.write(dernierCoupRobot);
        Wire.endTransmission();
        
        robotEnTrainDeJouer = true;
        Serial.print("Premier coup joue : "); Serial.println(dernierCoupRobot);
    }
}

void loop() {
    // --- CAS 0 : ATTENDRE LE COUP DE L'ADVERSAIRE ---
    if (role == 0 && !robotEnTrainDeJouer) {
        if (radio.available()) {
            char msg[32] = "";
            radio.read(&msg, sizeof(msg));
            int coupAdversaire = atoi(msg);

            if (coupAdversaire >= 0 && coupAdversaire <= 8 && board[coupAdversaire] == 0) {
                board[coupAdversaire] = 1;
                Serial.print("Adversaire a joue : "); Serial.println(coupAdversaire);

                dernierCoupRobot = calculerMeilleurCoup();
                if (dernierCoupRobot != -1) {
                    board[dernierCoupRobot] = -1;
                    Wire.beginTransmission(8);
                    Wire.write(dernierCoupRobot);
                    Wire.endTransmission();
                    robotEnTrainDeJouer = true;
                    // On bascule temporairement en emetteur pour répondre plus tard
                    radio.stopListening();
                    radio.openWritingPipe(adresse);
                    role = 1; 
                }
            }
        }
    }

    // --- SURVEILLANCE I2C ET ENVOI DU COUP ---
    if (robotEnTrainDeJouer) {
        static unsigned long lastCheck = 0;
        if (millis() - lastCheck > 500) {
            lastCheck = millis();
            Wire.requestFrom(8, 1);
            if (Wire.available()) {
                if (Wire.read() == FINI) {
                    robotEnTrainDeJouer = false;
                    
                    // Envoi du coup par NRF
                    char msg[32];
                    itoa(dernierCoupRobot, msg, 10);
                    radio.write(&msg, sizeof(msg));
                    Serial.println("Coup envoye à l'adversaire.");

                    // Après avoir envoyé, on redevient récepteur pour attendre l'autre
                    radio.openReadingPipe(1, adresse);
                    radio.startListening();
                    role = 0; 
                }
            }
        }
    }
}
