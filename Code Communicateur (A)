#include <SPI.h>
#include <RF24.h>
#include <Wire.h>

// --- CONFIGURATION NRF---
#define pinCE   A1
#define pinCSN  A0
#define tunnel  "PIPE1"
RF24 radio(pinCE, pinCSN);
const byte adresse[6] = tunnel;

// --- CONFIGURATION BLUETOOTH ---
#define bluetooth Serial1 

// --- ÉTATS I2C ---
#define FINI    0x01
#define TRAVAIL 0x02

// --- VARIABLES DE JEU ---
int board[9] = {0}; // 0=vide, 1=adversaire (X), -1=robot (O)
bool robotEnTrainDeJouer = false;

// --- LOGIQUE MINIMAX ---
int gagnant(int b[9]) {
    const int L[8][3] = {{0,1,2},{3,4,5},{6,7,8},{0,3,6},{1,4,7},{2,5,8},{0,4,8},{2,4,6}};
    for (int i = 0; i < 8; i++) {
        if (b[L[i][0]] != 0 && b[L[i][0]] == b[L[i][1]] && b[L[i][1]] == b[L[i][2]]) return b[L[i][0]];
    }
    return 0;
}

int minimax(int b[9], int joueur) {
    int win = gagnant(b);
    if (win == -1) return 1;
    if (win == 1) return -1;
    bool plein = true;
    for(int i=0; i<9; i++) if(b[i]==0) plein = false;
    if(plein) return 0;

    int meilleur = (joueur == -1 ? -1000 : 1000);
    for (int i = 0; i < 9; i++) {
        if (b[i] == 0) {
            b[i] = joueur;
            int score = minimax(b, -joueur);
            b[i] = 0;
            if (joueur == -1) meilleur = max(meilleur, score);
            else meilleur = min(meilleur, score);
        }
    }
    return meilleur;
}

int calculerMeilleurCoup() {
    int meilleurScore = -1000;
    int coup = -1;
    for (int i = 0; i < 9; i++) {
        if (board[i] == 0) {
            board[i] = -1;
            int score = minimax(board, 1);
            board[i] = 0;
            if (score > meilleurScore) {
                meilleurScore = score;
                coup = i;
            }
        }
    }
    return coup;
}

void setup() {
    Serial.begin(9600);      // Debug PC
    bluetooth.begin(9600);   // Bluetooth (Pins 0 & 1)
    Wire.begin();            // Maître I2C
    
    if (!radio.begin()) {
        bluetooth.println("Erreur: NRF24 non detecte !");
    }
    radio.openReadingPipe(1, adresse);
    radio.setPALevel(RF24_PA_MIN);
    radio.startListening(); 

    bluetooth.println("--- SYSTEME PRET : EN ATTENTE DU JOUEUR ---");
}

void loop() {
    // 1. ÉCOUTER L'ADVERSAIRE (NRF24)
    if (!robotEnTrainDeJouer && radio.available()) {
        char msgRecu[32] = "";
        radio.read(&msgRecu, sizeof(msgRecu));
        int coupAdversaire = atoi(msgRecu); // On attend un chiffre entre 0 et 8

        if (coupAdversaire >= 0 && coupAdversaire <= 8 && board[coupAdversaire] == 0) {
            board[coupAdversaire] = 1;
            bluetooth.print("Adversaire a joue case : "); bluetooth.println(coupAdversaire);

            // CALCUL DU COUP DU ROBOT
            int monCoup = calculerMeilleurCoup();
            if (monCoup != -1) {
                board[monCoup] = -1;
                
                // ENVOI DE L'ORDRE À L'ARDUINO B
                Wire.beginTransmission(8);
                Wire.write(monCoup); 
                Wire.endTransmission();
                
                robotEnTrainDeJouer = true; // On bloque les nouvelles entrées
                bluetooth.print("Robot joue case : "); bluetooth.println(monCoup);
            }
        }
    }

    // 2. SURVEILLANCE DU MOUVEMENT (I2C)
    if (robotEnTrainDeJouer) {
        static unsigned long dernierCheck = 0;
        if (millis() - dernierCheck > 500) { // On interroge B toutes les 500ms
            dernierCheck = millis();
            
            Wire.requestFrom(8, 1); 
            if (Wire.available()) {
                byte statut = Wire.read();
                if (statut == FINI) { 
                    robotEnTrainDeJouer = false;
                    bluetooth.println("Robot est revenu a sa base. Tour suivant.");
                }
            }
        }
    }
}
